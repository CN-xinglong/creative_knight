{
  "format_version": "1.8.0",
  "animations": {
    "animation.knight.idle": {
      "loop": true
    },
    "animation.knight.walk": {
      "loop": true
    },
    "animation.knight.attack": {
      "loop": false
    }
  },
  "animation_controllers": {
    "controller.animation.knight": {
      "states": {
        "default": {
          "animations": ["idle"],
          "transitions": [
            {"moving": "query.is_moving"}
          ]
        },
        "moving": {
          "animations": ["walk"],
          "transitions": [
            {"default": "!query.is_moving"}
          ]
        }
      }
    }
  }
}
